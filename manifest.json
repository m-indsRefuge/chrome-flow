{
  "manifest_version": 3,
  "minimum_chrome_version": "114",
  "name": "Chrome Flow",
  "version": "0.1.0",
  "description": "A local-first browser cognitive workspace for tab aliases, journaling, and search journey organization.",
  "permissions": [
    "tabs",
    "storage",
    "sidePanel",
    "windows"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },
  "action": {
    "default_title": "Open Chrome Flow"
  }
}
